  "dependencies": {
    "@types/three": "^0.166.0",
    "expo": "~56.0.12",
    "expo-asset": "~56.0.17",
    "expo-gl": "~56.0.5",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-three": "^8.0.0",
    "lucide-react-native": "^1.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
