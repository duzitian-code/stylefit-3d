  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "reconstruction:api": "node server/reconstruction-api.mjs",
    "reconstruction:bundle:bootstrap": "python3 -m workers.stylefit_avatar.create_parametric_bundle",
    "reconstruction:worker:stylefit": "uvicorn workers.stylefit_avatar.worker:app --host 0.0.0.0 --port 8791",
    "reconstruction:worker:stylefit:parametric": "STYLEFIT_AVATAR_ENABLE_PARAMETRIC_MVP=1 uvicorn workers.stylefit_avatar.worker:app --host 0.0.0.0 --port 8791",
    "reconstruction:worker:triposr": "uvicorn workers.triposr.worker:app --host 0.0.0.0 --port 8790"
  },
  "private": true
}
